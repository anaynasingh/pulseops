# Your personal PulseOps MCP token (long-lived API key).
# Get it from the PulseOps sidebar -> "Claude connected/setup" modal, or GET /api/v1/auth/api-key
PULSEOPS_API_KEY=paste-your-mcp-token-here
PULSEOPS_API_URL=http://localhost:8001/api/v1

# Bridge settings (defaults are fine)
# Bind address. Default 127.0.0.1 (loopback only — /chat has no auth, keep it
# private on a laptop). The Docker image sets BRIDGE_HOST=:: so the container is
# reachable over Railway's IPv6-only private networking.
# BRIDGE_HOST=127.0.0.1
# Port resolution: PORT (injected by Railway) wins over BRIDGE_PORT; default 8765.
BRIDGE_PORT=8765
CLAUDE_TIMEOUT_SECONDS=540
CLAUDE_MAX_TURNS=40

# Microsoft 365 (Outlook email + calendar via the m365 MCP server).
# Leave M365_CLIENT_ID unset to run without email tools (pulseops tools still work).
# M365_CLIENT_ID=your-azure-app-client-id
# M365_TENANT_ID=your-tenant-id
# M365_CLIENT_SECRET=            # optional; leave unset for the public-client device-code app
# M365_TOKEN_CACHE=/data/m365-token.json   # where the MSAL token cache lives (default ~/.pulseops_m365_token.json)
# M365_ALLOW_DEVICE_FLOW=1      # set ONLY for the one-time interactive cache seeding; never in server context

# Only set if the claude CLI is not on PATH
# CLAUDE_CLI_PATH=C:\Users\you\AppData\Roaming\npm\claude.cmd

# Python used to run the MCP server (defaults to the python running the bridge)
# PYTHON_CMD=python
