# Your personal PulseOps MCP token (long-lived API key).
# Get it from the PulseOps sidebar -> "Claude connected/setup" modal, or GET /api/v1/auth/api-key
PULSEOPS_API_KEY=paste-your-mcp-token-here
PULSEOPS_API_URL=http://localhost:8001/api/v1

# Bridge settings (defaults are fine for local dev)
BRIDGE_PORT=8765
CLAUDE_TIMEOUT_SECONDS=540
CLAUDE_MAX_TURNS=40

# Only set if the claude CLI is not on PATH
# CLAUDE_CLI_PATH=C:\Users\you\AppData\Roaming\npm\claude.cmd

# Python used to run the MCP server (defaults to the python running the bridge)
# PYTHON_CMD=python

# ── Deploy-only (Railway) ─────────────────────────────────────────────────────
# These are set on the Railway service, NOT needed for local dev.
#
# Claude subscription auth for headless mode. Generate on your own machine with:
#   claude setup-token   (a ~1-year OAuth token tied to your Claude Pro/Max plan)
# CLAUDE_CODE_OAUTH_TOKEN=paste-the-setup-token-here
#
# DO NOT set ANTHROPIC_API_KEY on this service — it outranks the OAuth token and
# forces per-token API billing instead of using your subscription.
#
# Bind host. Railway needs 0.0.0.0 (the Dockerfile already sets this). Locally
# leave it unset so the bridge stays on 127.0.0.1.
# BRIDGE_HOST=0.0.0.0
#
# Railway injects $PORT; the bridge prefers it over BRIDGE_PORT automatically.
#
# Shared secret the PulseOps backend must send as X-Bridge-Secret. Set the same
# value here and on the backend service (BRIDGE_SECRET). Leave empty locally.
# BRIDGE_SECRET=generate-a-long-random-string
