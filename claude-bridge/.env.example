# Your personal PulseOps MCP token (long-lived API key).
# Get it from the PulseOps sidebar -> "Claude connected/setup" modal, or GET /api/v1/auth/api-key
PULSEOPS_API_KEY=paste-your-mcp-token-here
PULSEOPS_API_URL=http://localhost:8001/api/v1

# Bridge settings (defaults are fine)
BRIDGE_PORT=8765
CLAUDE_TIMEOUT_SECONDS=540
CLAUDE_MAX_TURNS=40

# Only set if the claude CLI is not on PATH
# CLAUDE_CLI_PATH=C:\Users\you\AppData\Roaming\npm\claude.cmd

# Python used to run the MCP server (defaults to the python running the bridge)
# PYTHON_CMD=python
