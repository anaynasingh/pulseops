{
  "mcpServers": {
    "pulseops": {
      "command": "python",
      "args": ["mcp-servers/pulseops/server.py"],
      "env": {
        "PULSEOPS_API_URL": "http://localhost:8001/api/v1",
        "PULSEOPS_API_KEY": ""
      }
    },
    "m365": {
      "command": "python",
      "args": ["mcp-servers/m365/server.py"],
      "env": {
        "M365_CLIENT_ID": "",
        "M365_TENANT_ID": "common"
      }
    }
  }
}
